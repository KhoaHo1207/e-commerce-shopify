```gitignore
# ===================================
# Dependencies
# ===================================
node_modules/
.pnpm-store/

# ===================================
# Build
# ===================================
dist/
coverage/
*.tsbuildinfo

# ===================================
# Environment Variables
# ===================================
.env
.env.*
!.env.example

# ===================================
# Logs
# ===================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================================
# Runtime
# ===================================
*.pid
*.seed
*.pid.lock

# ===================================
# Cache
# ===================================
.cache/
.eslintcache

# ===================================
# IDE
# ===================================
.vscode/
!.vscode/extensions.json

.idea/
*.iml

# ===================================
# OS
# ===================================
.DS_Store
Thumbs.db
Desktop.ini

# ===================================
# Temporary Files
# ===================================
tmp/
temp/

# ===================================
# Test
# ===================================
.nyc_output/

# ===================================
# PM2
# ===================================
.pm2/
```
